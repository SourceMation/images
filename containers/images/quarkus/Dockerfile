FROM sourcemation/rocky-9:latest
SHELL ["/bin/bash", "-o", "pipefail", "-c"]

ARG BUILD_DATE
ARG TARGETARCH

# YOU MUST CHANGE IT MANUALLY HERE AND IN THE LABEL!
ARG QUARKUS_VERSION=3.32.3

LABEL name="quarkus" \
      vendor="Sourcemation" \
      url="https://sourcemation.com"\
      licenses="Apache-2.0" \
      created="$BUILD_DATE" \
      architecture="$TARGETARCH" \
      summary="Quarkus development container on RL9" \
      description="Provides Quarkus development container on Rocky Linux 9" \
      version="3.32.3" \
      org.opencontainers.image.source="https://github.com/Sourcemation/images" \
      io.k8s.display-name="Quarkus on EL9 Container" \
      io.k8s.description="Provides Quarkus on Rocky Linux 9" \
      io.openshift.tags="quarkus rockylinux"


RUN useradd -ms /bin/bash quarkus
USER quarkus
WORKDIR /home/quarkus

# Install Quarkus with JBang - Bang bang!
# install jbang
RUN curl -sL https://sh.jbang.dev -o jbang.sh && \
    sha256sum --check <( echo "462d7b6ca8eb2aa8a0464acb4b8b40cdf791e07d06533c64de9e11fb92975c0c jbang.sh" ) && \
    cat jbang.sh | bash -s - app setup

# modify the PATH to include jbang
ENV PATH="/home/quarkus/.jbang/bin:/home/quarkus/.jbang/currentjdk/bin:${PATH}"

# Trust the Quarkus Maven repo and Install Quarkus CLI
RUN mkdir -p /home/quarkus/.local/bin && \
    cd /home/quarkus/.local/bin && \
    jbang trust add https://repo1.maven.org/maven2/io/quarkus/quarkus-cli/ && \
    jbang app install --name quarkus https://repo1.maven.org/maven2/io/quarkus/quarkus-cli/${QUARKUS_VERSION}/quarkus-cli-${QUARKUS_VERSION}-runner.jar

# Wrap quarkus create app to remove stale Maven wrapper checksums generated by
# upstream templates, which break ./mvnw in tests.
RUN mv /home/quarkus/.jbang/bin/quarkus /home/quarkus/.jbang/bin/quarkus-real && \
    cat > /home/quarkus/.jbang/bin/quarkus <<EOF
#!/usr/bin/env bash
set -euo pipefail

/home/quarkus/.jbang/bin/quarkus-real "$@"

if [[ "$#" -ge 2 && "$1" == "create" && "$2" == "app" ]]; then
    output_dir="."
    args=("$@")
    for ((i=0; i<${#args[@]}; i++)); do
        if [[ "${args[$i]}" == "--output-directory" && $((i + 1)) -lt ${#args[@]} ]]; then
            output_dir="${args[$((i + 1))]}"
            break
        fi
    done

    find "$output_dir" -type f -path '*/.mvn/wrapper/maven-wrapper.properties' \
        -exec sed -i '/distributionSha256Sum/d' {} +
fi
EOF


RUN chmod +x /home/quarkus/.jbang/bin/quarkus && \
    echo "quarkus: ${QUARKUS_VERSION}" >> /var/tmp/sourcemation.yml && \
    jbang_version=$(cat /home/quarkus/.jbang/cache/urls/jbang/version.txt  | grep -oP '^\d+\.\d+\.\d+' ) && \
    echo "jbang: ${jbang_version}" >> /var/tmp/sourcemation.yml

# Pre-warm the Maven Wrapper distribution cache so tests can run ./mvnw offline.
# Quarkus 3.x Maven Wrapper no longer bundles maven-wrapper.jar and downloads
# Maven on first use; without this the test ./mvnw call fails.
# The distributionSha256Sum generated by quarkus create app can be stale/wrong,
# so we strip it here to allow the initial download. Once Maven is cached in
# ~/.m2/wrapper/dists/ the wrapper reuses the cache without re-validating.
RUN cd /tmp && \
    quarkus create app com.example.warmup --no-code && \
    cd com.example.warmup && \
    chmod +x mvnw && \
    sed -i '/distributionSha256Sum/d' .mvn/wrapper/maven-wrapper.properties && \
    ./mvnw package -Dquarkus.package.type=uber-jar -DskipTests -q && \
    cd /home/quarkus && \
    rm -rf /tmp/com.example.warmup

CMD ["/bin/bash"]
